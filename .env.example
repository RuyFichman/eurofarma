# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local (esta no .gitignore).

# Conexao com o Postgres (Supabase).
# Pegue a string exata em: Dashboard > Project Settings > Database > Connection string
# - Conexao direta (migrations): porta 5432
# - Conexao via pooler (runtime serverless): porta 6543 com ?pgbouncer=true
DATABASE_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres"
